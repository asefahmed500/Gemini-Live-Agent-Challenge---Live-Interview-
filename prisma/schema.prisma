generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  cvContent      String?   @db.Text   // Extracted CV/resume text
  jobDescription String?   @db.Text   // Target job description
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  interviewSessions InterviewSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InterviewSession {
  id                 String          @id @default(cuid())
  userId             String?
  jobRole            String
  difficulty         String          @default("medium")
  status             String          @default("created")
  startedAt          DateTime        @default(now())
  endedAt            DateTime?
  overallScore       Float?
  confidenceScore    Float?
  communicationScore Float?
  technicalScore     Float?
  cvContent          String?         @db.Text   // CV used for this interview
  jobDescription     String?         @db.Text   // Job description used
  interviewType      String          @default("chat") // chat, video, voice
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  confidenceLog      ConfidenceLog[]
  report             Report?
  transcripts        Transcript[]

  @@map("interview_sessions")
}

model Transcript {
  id        String           @id @default(cuid())
  sessionId String
  role      String
  content   String
  timestamp DateTime         @default(now())
  metadata  Json?
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

model ConfidenceLog {
  id                String           @id @default(cuid())
  sessionId         String
  timestamp         DateTime         @default(now())
  eyeContact        Float?
  posture           Float?
  facialExpression  Float?
  voiceTone         Float?
  speechClarity     Float?
  overallConfidence Float?
  session           InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("confidence_logs")
}

model Report {
  id                 String           @id @default(cuid())
  sessionId          String           @unique
  communicationScore Float?
  technicalScore     Float?
  confidenceScore    Float?
  overallScore       Float?
  strengths          String[]
  improvements       String[]
  suggestions        String[]
  summary            String
  detailedFeedback   String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  session            InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("reports")
}
